# Secure Alpha Telemetry Loop — Required Environment Variables
# Never commit real values to git. Set these in your deployment dashboard.

# Admin dashboard access token (used by /api/internal/telemetry-analytics)
ADMIN_TELEMETRY_TOKEN=Your Private Alpha Dashboard Access Phrase

# Supabase serverless database (public anon key for client-side operations)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key-here

# Direct PostgreSQL connection (Drizzle ORM / local pool)
DATABASE_URL=postgresql://user:password@localhost:5432/morphix

# Replit managed (pre-provisioned)
SESSION_SECRET=your-session-secret-here
